# Servidor ERP elegido para auditoria/aplicacion contra MariaDB produccion
sync_host=192.168.0.231

# Produccion real MSSQL; no consultar servidor de pruebas en auditoria de produccion
audit_hosts=192.168.0.231

# Ventana configurable para conservar en auditoria productos marcados EXCLUIR_SIN_MOVIMIENTO si tuvieron compra reciente
purchase_movement_window_days=60
purchase_movement_host=192.168.0.231
